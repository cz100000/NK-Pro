        }
      }
    },
    {
      "sequence": 2,
      "ruleId": "NKP-FACH-002",
      "title": "Mindestens eine aktive Wohnung ist vorhanden",
      "category": "Fachliche Pflicht- und Konsistenzprüfung",
      "area": "Objekt und Abrechnungszeitraum",
      "auditStatus": "fachlich und technisch analysiert – Entscheidung/Korrektur ausstehend",
      "technicalChangeStatus": "Korrektur erforderlich",
      "userDecisionStatus": "Behandlung fehlender/ungültiger Wohnungsstatuswerte festzulegen",
      "auditDimensions": {
        "dataSource": "Präzisieren auf die abrechnungsbezogene Kopie wohnungen[].id und wohnungen[].status. Die zentrale Wohnungsverwaltung enthält bewusst keinen abrechnungsbezogenen Aktivstatus.",
        "calculation": "Korrektur erforderlich: Die Regel wertet jeden Status außer „inaktiv“ als aktiv. Die Umlageberechnung zählt dagegen nur exakt „aktiv“. Dadurch können leere, unbekannte oder anders geschriebene Statuswerte die Regel bestehen lassen, obwohl die Berechnung keine aktive Wohnung verwendet.",
        "triggerAndPrerequisites": "Muss bei jeder geöffneten Abrechnung, nach Stammdatenübernahme, nach Statusänderung und vor Abschluss laufen. Fehlende Wohnungen oder Statuswerte sind Fehler, keine fehlende Voraussetzung.",
        "notApplicableLogic": "Nicht anwendbar ist fachlich nicht zulässig.",
        "severity": "Fehler ist korrekt.",
        "blockingEffect": "Blockierend ist korrekt, weil ohne eindeutig aktive Wohnung keine belastbare Verteilungsbasis existiert.",
        "confirmation": "Keine Bestätigung oder Übersteuerung ist korrekt.",
        "directEntry": "Korrektur erforderlich: wohnungsverwaltung zeigt den zentralen Bestand, aber keinen Status der geöffneten Abrechnung. Richtiger Direkteinstieg ist mieter → #tenantUnitsSection beziehungsweise #wohnungenTable.",
        "resultValues": "Erweitern um Gesamtzahl, aktive, inaktive, fehlende/ungültige Statuswerte sowie betroffene Wohnungs-IDs.",
        "textsAndStatuses": "„Keine aktive Wohnung vorhanden“ ist bei ungültigen Statuswerten zu pauschal. Meldungen müssen zwischen leerem Bestand, sämtlich inaktiv und ungültigem Status unterscheiden.",
        "detailAndPresentation": "Direkte Markierung der Wohnungszeile beziehungsweise der Statustabelle; bei mehreren ungültigen Werten je Wohnung ein eigener Ergebnisdatensatz.",
        "tests": "Erforderlich für leeren Bestand, alle inaktiv, exakt aktiv, bekannte Groß-/Kleinschreibung, fehlenden Status, unbekannten Status und richtigen Direkteinstieg."
      },
      "findings": [
        {
          "severity": "hoch",
          "type": "false-positive",
          "evidence": "Eine Wohnung mit leerem Status oder Status „Aktiv“ wird von NKP-FACH-002 als aktiv gezählt. activeWohnungen() in billing-calculation.js zählt jedoch nur status === „aktiv“.",
          "cause": "Regel und Berechnung verwenden unterschiedliche Aktivdefinitionen."
        },
        {
          "severity": "hoch",
          "type": "silent-exclusion",
          "evidence": "Unbekannte Werte wie „leerstand“ gelten in der Regel als aktiv, werden in der Umlageberechnung aber ausgeschlossen.",
          "cause": "Die Regel behandelt nur den exakten Wert „inaktiv“ als nicht aktiv."
        },
        {
          "severity": "mittel",
          "type": "wrong-direct-entry",
          "evidence": "targetTab wohnungsverwaltung enthält keinen abrechnungsbezogenen Status. Der Status ist in Mieter & Wohnungen bearbeitbar.",
          "cause": "Verwechslung von zentralem Wohnungsbestand und Abrechnungskopie."
        },
        {
          "severity": "mittel",
          "type": "insufficient-result-data",
          "evidence": "Das Ergebnis enthält nur count und keine Aufschlüsselung nach aktiv, inaktiv oder ungültig.",
          "cause": "Statusklassifikation wird nicht dokumentiert."
        }
      ],
      "decision": {
        "retainRuleId": true,
        "recommendedTargetPage": "mieter",
        "recommendedTargetSelector": "#tenantUnitsSection",
        "recommendedBehavior": "Bekannte Legacy-Schreibweisen Aktiv/Inaktiv beim Laden auf aktiv/inaktiv normalisieren. Nur der kanonische Status aktiv zählt. Leere oder unbekannte Werte sind blockierende Statusfehler und werden je Wohnung ausgewiesen.",
        "recommendedConsistency": "Eine gemeinsame Hilfsfunktion für Qualitätsregel, Umlageberechnung, Dashboards und Snapshot-Prüfung verwenden.",
        "explicitlyNotIncluded": "Eine inaktive Wohnung wird nicht automatisch aktiviert; Leerstand wird nicht über einen dritten Wohnungsstatus modelliert, sondern über aktive Wohnung ohne abrechenbares Mietverhältnis."
      },
      "notes": "Noch nicht umgesetzt. Nutzerfreigabe erforderlich."
    },
