  "rules": [
    {
      "sequence": 1,
      "ruleId": "NKP-FACH-001",
      "title": "Abrechnungszeitraum ist gültig",
      "category": "Fachliche Pflicht- und Konsistenzprüfung",
      "area": "Objekt und Abrechnungszeitraum",
      "auditStatus": "vollständig geprüft, freigegeben, umgesetzt und getestet",
      "technicalChangeStatus": "umgesetzt und regressionsgetestet",
      "userDecisionStatus": "freigegeben am 16.07.2026",
      "auditDimensions": {
        "dataSource": "Korrektur erforderlich: abrechnungsjahr fehlt in der deklarierten Datenquelle, obwohl es für Konsistenz und Fingerabdruck relevant ist.",
        "calculation": "Korrektur erforderlich: Date.parse akzeptiert unmögliche Kalendertage durch Normalisierung (z. B. 2025-02-30). Exakte ISO- und Kalenderprüfung fehlt.",
        "triggerAndPrerequisites": "Regel muss bei jeder geöffneten Abrechnung und vor Abschluss laufen; fehlende Werte sind selbst ein Fehler und keine fehlende Voraussetzung.",
        "notApplicableLogic": "Nicht anwendbar ist fachlich nicht zulässig.",
        "severity": "Fehler ist korrekt.",
        "blockingEffect": "Blockierend ist korrekt.",
        "confirmation": "Keine Bestätigung/Übersteuerung ist korrekt.",
        "directEntry": "Korrektur erforderlich: Zielseite einstellungen enthält nur Kostenarten und keine Periodenfelder.",
        "resultValues": "Erweitern um Abrechnungsjahr, Start, Ende, validierte Kalenderwerte, Dauer und Fehlerart.",
        "textsAndStatuses": "Statuslogik korrekt; Meldung ist zu pauschal und sollte fehlend, Format, unmögliches Datum, Reihenfolge und Jahresabweichung unterscheiden.",
        "detailAndPresentation": "Korrektur erforderlich: kein eindeutiges Ziel-Element; ein bearbeitbarer Periodenbereich auf der Abrechnungsübersicht wird empfohlen.",
        "tests": "AP21-Regression vorhanden: fehlend, Formatabweichung, unmöglicher Kalendertag, Reihenfolge, Jahresinkonsistenz, Teilperiode, jahresübergreifende Periode und UI-Direkteinstieg."
      },
      "findings": [
        {
          "severity": "hoch",
          "type": "false-negative",
          "evidence": "2025-02-30 bis 2025-12-31 wird aktuell als Erledigt bewertet.",
          "cause": "Date.parse normalisiert den 30. Februar auf den 2. März."
        },
        {
          "severity": "hoch",
          "type": "missing-consistency-check",
          "evidence": "Abrechnungsjahr 2024 mit Zeitraum 2025-01-01 bis 2025-12-31 wird aktuell als Erledigt bewertet.",
          "cause": "meta.abrechnungsjahr wird in der Auswertung nicht geprüft."
        },
        {
          "severity": "mittel",
          "type": "wrong-direct-entry",
          "evidence": "targetTab ist einstellungen; dort sind keine Felder für Abrechnungsjahr, Beginn oder Ende vorhanden.",
          "cause": "Registry-Ziel wurde aus der alten Seitenstruktur übernommen."
        },
        {
          "severity": "mittel",
          "type": "insufficient-message",
          "evidence": "Alle Fehlerfälle erhalten nur die Sammelmeldung „Zeitraum … ist ungültig“.",
          "cause": "Keine fachlichen Untergründe/Fehlerarten im Ergebnis."
        }
      ],
      "decision": {
        "retainRuleId": true,
        "recommendedTargetPage": "start",
        "recommendedTargetSelector": "#billingPeriodSettings",
        "recommendedBehavior": "Kompakter Bereich „Abrechnungszeitraum“ auf der Abrechnungsübersicht; im Bearbeitungsmodus editierbar, in Ansicht/Archiv schreibgeschützt.",
        "recommendedValidation": [
          "Pflichtfelder vorhanden",
          "exaktes Format YYYY-MM-DD",
          "tatsächlich existierendes Kalenderdatum",
          "Ende nicht vor Beginn",
          "Abrechnungsjahr entspricht dem Endjahr der Periode"
        ],
        "explicitlyNotIncluded": "Keine automatische 12-Monats- oder Kalenderjahrspflicht ohne gesonderte fachliche Entscheidung."
      },
      "notes": "Umgesetzt in quality-rules.js, billing-workflow.js, app.js, ui-bindings.js, billing-context.js, ui-navigation-pages.js, index.html und app.css. Architekturtests AP6–AP21 bestanden. App-Browserlauf in der Arbeitsumgebung durch Hostrichtlinie blockiert; vollständiger lokaler Playwright-Lauf bleibt als spätere Gesamtprüfung vorgesehen.",
      "implementation": {
        "status": "implemented",
        "approvedAt": "2026-07-16",
        "targetTab": "start",
        "targetSelector": "#billingPeriodSettings",
        "testFile": "tests/ap21-rule-audit.test.cjs",
