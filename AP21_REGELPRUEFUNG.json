          "tests/ap21-rule-audit.test.cjs"
        ],
        "testStatus": {
          "staticAndDomainTests": "passed",
          "releaseConsistency": "passed",
          "chromiumLaunch": "passed",
          "appBrowserRun": "blocked-by-host-policy",
